# Supabase Configuration (Required)
# Get these from: https://app.supabase.com/project/_/settings/api
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: TURN relay for reliable mobile WebRTC
# Comma-separated URLs are supported.
# Example:
# VITE_TURN_URL=turn:turn.example.com:3478?transport=udp,turns:turn.example.com:5349
# VITE_TURN_USERNAME=turn-user
# VITE_TURN_CREDENTIAL=turn-password

# Optional: For local development with custom Supabase instance
# VITE_SUPABASE_URL=http://localhost:54321
# VITE_SUPABASE_ANON_KEY=your-local-anon-key

# Notes:
# - VITE_SUPABASE_URL: Your Supabase project URL
# - VITE_SUPABASE_ANON_KEY: The anon/public key from Supabase API settings
# - Never commit your actual .env file to version control
# - The service role key should NEVER be in frontend .env files
# - Service role key is only used in Supabase Edge Functions

# Edge Function Environment Variables (for deployment)
# These go in Supabase Edge Function secrets, NOT in this file:
# - SUPABASE_URL
# - SUPABASE_ANON_KEY
# - SERVICE_ROLE_KEY
# - FIREBASE_PROJECT_ID
# - FIREBASE_CLIENT_EMAIL
# - FIREBASE_PRIVATE_KEY
